# ===== Alpaca (paper) =====
# https://app.alpaca.markets/ → Paper Trading → API Keys 생성
ALPACA_API_KEY=PK_your_paper_key
ALPACA_SECRET_KEY=your_paper_secret
ALPACA_PAPER=true

# ===== Google Sheet 대시보드 =====
# 1) Google Cloud → 서비스계정 생성 → JSON 키 다운로드 → 아래 경로 지정
# 2) 대상 스프레드시트를 서비스계정 이메일(xxx@xxx.iam.gserviceaccount.com)과 '편집자' 공유
GOOGLE_SA_JSON=./secrets/service_account.json
DASHBOARD_SHEET_ID=your_google_spreadsheet_id
